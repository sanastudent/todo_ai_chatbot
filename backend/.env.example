# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost/todo_chatbot_dev

# OpenRouter / Gemini Configuration
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
OPENROUTER_MODEL=google/gemini-pro
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
HTTP_REFERER=http://localhost:8000
X_TITLE=Todo AI Chatbot


# Context7 Configuration (Optional)
# Get your API key from https://context7.com
CONTEXT7_API_KEY=your-context7-api-key-here
CONTEXT7_ENABLED=false

# API Configuration
API_HOST=0.0.0.0
# API_PORT=8000
API_PORT=8001



CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# Better Auth (Optional - for Phase 5)
# BETTER_AUTH_SECRET=your-secret-key-here
# BETTER_AUTH_URL=http://localhost:8000

