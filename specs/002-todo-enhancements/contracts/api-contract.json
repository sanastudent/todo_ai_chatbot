# API Contract: Todo AI Chatbot Enhanced MCP Tools

## Overview
This document defines the API contracts for the enhanced MCP tools that support priority levels, tagging system, search functionality, filtering capabilities, and sorting options.

## Updated MCP Tool Specifications

### 1. add_task (Enhanced)

#### Description
Create a new task for the user with optional priority and tags.

#### Input Parameters
```json
{
  "user_id": {
    "type": "string",
    "required": true,
    "description": "User identifier (must match authenticated user)",
    "validation": {
      "min_length": 1,
      "max_length": 255
    }
  },
  "title": {
    "type": "string",
    "required": true,
    "description": "Short description of the task (what needs to be done)",
    "validation": {
      "min_length": 1,
      "max_length": 200
    }
  },
  "description": {
    "type": "string",
    "required": false,
    "description": "Optional additional details or notes about the task",
    "validation": {
      "max_length": 2000
    }
  },
  "priority": {
    "type": "string",
    "required": false,
    "description": "Priority level of the task",
    "default": "medium",
    "enum": ["high", "medium", "low"],
    "validation": {
      "enum_values": ["high", "medium", "low"]
    }
  },
  "tags": {
    "type": "array",
    "items": {
      "type": "string"
    },
    "required": false,
    "description": "Array of tag strings for categorization",
    "default": [],
    "validation": {
      "max_items": 10,
      "item_min_length": 1,
      "item_max_length": 50,
      "pattern": "^[a-zA-Z0-9_-]+$"
    }
  }
}
```

#### Output Response
```json
{
  "type": "object",
  "properties": {
    "task_id": {
      "type": "string",
      "description": "Unique identifier of the created task"
    },
    "title": {
      "type": "string",
      "description": "Title of the created task"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the task was created"
    },
    "was_duplicate": {
      "type": "boolean",
      "description": "Indicates if the task already existed and was returned instead of created"
    }
  },
  "required": ["task_id", "title", "created_at", "was_duplicate"]
}
```

#### Error Responses
- `400 Bad Request`: Invalid input parameters
- `401 Unauthorized`: Invalid user_id
- `500 Internal Server Error`: Database operation failed

---

### 2. list_tasks (Enhanced)

#### Description
Retrieve all tasks for the user with optional filtering, searching, and sorting capabilities.

#### Input Parameters
```json
{
  "user_id": {
    "type": "string",
    "required": true,
    "description": "User identifier (must match authenticated user)",
    "validation": {
      "min_length": 1,
      "max_length": 255
    }
  },
  "completed": {
    "type": "boolean",
    "required": false,
    "description": "Filter by completion status: true=only completed, false=only pending, omit=all tasks"
  },
  "priority": {
    "type": "array",
    "items": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "required": false,
    "description": "Filter by priority level(s)",
    "validation": {
      "max_items": 3
    }
  },
  "tags": {
    "type": "array",
    "items": {
      "type": "string"
    },
    "required": false,
    "description": "Filter by tag(s) - returns tasks containing ANY of the specified tags",
    "validation": {
      "max_items": 10,
      "item_min_length": 1,
      "item_max_length": 50,
      "pattern": "^[a-zA-Z0-9_-]+$"
    }
  },
  "search_term": {
    "type": "string",
    "required": false,
    "description": "Keyword to search in task title, description, or tags",
    "validation": {
      "min_length": 1,
      "max_length": 200
    }
  },
  "date_from": {
    "type": "string",
    "format": "date-time",
    "required": false,
    "description": "Filter tasks created after this date"
  },
  "date_to": {
    "type": "string",
    "format": "date-time",
    "required": false,
    "description": "Filter tasks created before this date"
  },
  "sort_by": {
    "type": "string",
    "required": false,
    "description": "Field to sort by",
    "default": "created_at",
    "enum": ["created_at", "priority", "title", "completed"],
    "validation": {
      "enum_values": ["created_at", "priority", "title", "completed"]
    }
  },
  "sort_order": {
    "type": "string",
    "required": false,
    "description": "Sort order",
    "default": "desc",
    "enum": ["asc", "desc"],
    "validation": {
      "enum_values": ["asc", "desc"]
    }
  },
  "limit": {
    "type": "integer",
    "required": false,
    "description": "Maximum number of tasks to return",
    "default": 50,
    "validation": {
      "minimum": 1,
      "maximum": 100
    }
  },
  "offset": {
    "type": "integer",
    "required": false,
    "description": "Number of tasks to skip for pagination",
    "default": 0,
    "validation": {
      "minimum": 0
    }
  }
}
```

#### Output Response
```json
{
  "type": "object",
  "properties": {
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string",
            "description": "Unique identifier of the task"
          },
          "title": {
            "type": "string",
            "description": "Title of the task"
          },
          "description": {
            "type": "string",
            "description": "Optional description of the task"
          },
          "completed": {
            "type": "boolean",
            "description": "Whether the task is completed"
          },
          "priority": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "Priority level of the task"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of tags associated with the task"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the task was created"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the task was last updated"
          }
        },
        "required": ["task_id", "title", "completed", "priority", "tags", "created_at"]
      },
      "description": "Array of tasks matching the criteria"
    },
    "total_count": {
      "type": "integer",
      "description": "Total number of tasks matching the criteria (for pagination)"
    },
    "filtered_by": {
      "type": "object",
      "description": "Filters that were applied to the results",
      "properties": {
        "priority": {
          "type": "array",
          "items": {"type": "string"}
        },
        "tags": {
          "type": "array",
          "items": {"type": "string"}
        },
        "search_term": {"type": "string"},
        "completed": {"type": "boolean"}
      }
    }
  },
  "required": ["tasks", "total_count"]
}
```

#### Error Responses
- `400 Bad Request`: Invalid input parameters
- `401 Unauthorized`: Invalid user_id
- `500 Internal Server Error`: Database operation failed

